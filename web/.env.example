# Dev server port — fixed per project to avoid collisions with other local apps.
# Keep in sync with the -p flag in package.json scripts and .claude/rules/dev-server.md
PORT=3977

# Canonical public site URL — used by robots.txt + sitemap.xml (and optional metadataBase).
# Production: https://dig.vllnt.com. In dev it falls back to http://localhost:3977.
# NEXT_PUBLIC_SITE_URL=https://dig.vllnt.com

# @vllnt/analytics — consent-gated analytics
# NEXT_PUBLIC_ANALYTICS_APP=dig-web
