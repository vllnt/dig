{
  "name": "dig-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "next dev -p 3977",
    "build": "next build",
    "start": "next start -p 3977",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "serve:tailscale": "tailscale serve --bg 3977 && tailscale serve status",
    "serve:tailscale:off": "tailscale serve reset",
    "test": "vitest run && playwright test",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:ui": "playwright test --ui"
  },
  "dependencies": {
    "@mdx-js/mdx": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@next/mdx": "^16.2.1",
    "@vllnt/analytics": "^0.1.1",
    "@vllnt/logger": "^0.1.2",
    "@vllnt/ui": "^0.2.1",
    "gray-matter": "^4.0.3",
    "lucide-react": "^1.17.0",
    "next": "^16.2.6",
    "next-intl": "^4.11.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "reading-time": "^1.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/typography": "^0.5.16",
    "@types/mdx": "^2.0.13",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitest/coverage-v8": "^4.1.8",
    "@vllnt/eslint-config": "^1.0.0",
    "@vllnt/typescript": "^1.0.0",
    "eslint": "^9.39.2",
    "postcss": "^8.5.0",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.9.3",
    "vitest": "^4.1.8"
  }
}
